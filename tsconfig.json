{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "node",
    "strict": true,
    "checkJs": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "types": ["vite/client", "vue"],
    "lib": ["es2017", "dom"], // 确保包含 es2017 或更高版本
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"]
}